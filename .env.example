# .env.example — Copy to .env and fill in your values
# DO NOT commit .env to version control

# ==========================================
# API Key — Choose ONE of the following:
# ==========================================

# Option 1: Coding Plan key (sk-sp-*) — for AI coding subscription users
# Get from: https://bailian.console.aliyun.com/ → Coding Plan
DASHSCOPE_API_KEY=sk-sp-xxx

# Option 2: Standard DashScope key (sk-*) — for pay-as-you-go users
# Get from: https://bailian.console.aliyun.com/ → API-KEY 管理
# DASHSCOPE_API_KEY=sk-xxx

# ==========================================
# Model Selection
# ==========================================

# For Coding Plan (sk-sp-*):
#   qwen3.5-plus, qwen3-coder-plus, qwen3-coder-next, kimi-k2.5, glm-5, MiniMax-M2.5
BAILIAN_MODEL=qwen3.5-plus

# For Standard key (sk-*):
#   qwen-max, qwen-plus, qwen-turbo, qwen-long
# BAILIAN_MODEL=qwen-max

# ==========================================
# Other Settings
# ==========================================
WIKI_AUTO_CONFIRM=false
